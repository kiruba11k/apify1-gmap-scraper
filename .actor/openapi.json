{
  "openapi": "3.0.0",
  "info": {
    "title": "Google Maps Company Leads API",
    "version": "1.0.0",
    "description": "API for accessing scraped Google Maps company leads."
  },
  "paths": {
    "/datasets/{datasetId}/items": {
      "get": {
        "summary": "Get company leads",
        "operationId": "getCompanyLeads",
        "parameters": [
          {
            "name": "datasetId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of company leads",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CompanyLead"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CompanyLead": {
        "type": "object",
        "properties": {
          "companyDomain": {
            "type": "string"
          },
          "companyIndustry": {
            "type": "string"
          },
          "companyName": {
            "type": "string"
          },
          "contactNumber": {
            "type": "string"
          },
          "emailId": {
            "type": "string"
          },
          "exactAddress": {
            "type": "string"
          },
          "googleMapsLink": {
            "type": "string"
          },
          "locationRegion": {
            "type": "string"
          },
          "reviewCount": {
            "type": "string"
          },
          "servicesOffered": {
            "type": "string"
          },
          "starRating": {
            "type": "string"
          },
          "totalCompaniesFound": {
            "type": "string"
          }
        }
      }
    }
  }
}
