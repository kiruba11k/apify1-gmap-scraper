{
  "openapi": "3.0.0",
  "info": {
    "title": "Google Maps Company Leads API",
    "description": "Web server API for accessing scraped Google Maps company lead data from the actor.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development server (Apify will overwrite this automatically in deployment)"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Health check endpoint",
        "responses": {
          "200": {
            "description": "Server is running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/companies": {
      "get": {
        "operationId": "getCompanies",
        "summary": "Get scraped company leads",
        "description": "Returns scraped company lead records.",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CompanyLead"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CompanyLead": {
        "type": "object",
        "properties": {
          "companyDomain": {
            "type": "string",
            "description": "Official company website URL"
          },
          "companyIndustry": {
            "type": "string",
            "description": "Industry or business category"
          },
          "companyName": {
            "type": "string",
            "description": "Registered or displayed company name"
          },
          "contactNumber": {
            "type": "string",
            "description": "Primary contact phone number"
          },
          "emailId": {
            "type": "string",
            "description": "Company email address"
          },
          "exactAddress": {
            "type": "string",
            "description": "Complete company address"
          },
          "googleMapsLink": {
            "type": "string",
            "description": "Google Maps business profile link"
          },
          "locationRegion": {
            "type": "string",
            "description": "City, state, or regional location"
          },
          "reviewCount": {
            "type": "integer",
            "description": "Total number of Google reviews"
          },
          "servicesOffered": {
            "type": "string",
            "description": "Main services or business offerings"
          },
          "starRating": {
            "type": "number",
            "description": "Google rating score"
          },
          "totalCompaniesFound": {
            "type": "integer",
            "description": "Total companies scraped in the run"
          }
        },
        "required": [
          "companyDomain",
          "companyIndustry",
          "companyName",
          "contactNumber",
          "emailId",
          "exactAddress",
          "googleMapsLink",
          "locationRegion",
          "reviewCount",
          "servicesOffered",
          "starRating",
          "totalCompaniesFound"
        ]
      }
    }
  }
}
