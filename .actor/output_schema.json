{
  "actorOutputSchemaVersion": 1,
  "title": "Google Maps Company Scraper Output",
  "description": "Structured company lead data scraped from Google Maps",
  "type": "object",
  "properties": {
    "companyDomain": {
      "type": ["string", "null"],
      "description": "Official company website URL"
    },
    "companyIndustry": {
      "type": ["string", "null"],
      "description": "Industry or business category"
    },
    "companyName": {
      "type": ["string", "null"],
      "description": "Registered or displayed company name"
    },
    "contactNumber": {
      "type": ["string", "null"],
      "description": "Primary contact phone number"
    },
    "emailId": {
      "type": ["string", "null"],
      "description": "Company email address"
    },
    "exactAddress": {
      "type": ["string", "null"],
      "description": "Complete company address"
    },
    "googleMapsLink": {
      "type": ["string", "null"],
      "description": "Google Maps business profile link"
    },
    "locationRegion": {
      "type": ["string", "null"],
      "description": "City, state, or regional location"
    },
    "reviewCount": {
      "type": ["integer", "null"],
      "description": "Total number of Google reviews"
    },
    "servicesOffered": {
      "type": ["string", "null"],
      "description": "Main services or business offerings"
    },
    "starRating": {
      "type": ["number", "null"],
      "description": "Google rating score"
    },
    "totalCompaniesFound": {
      "type": ["integer", "null"],
      "description": "Total companies scraped in the run"
    }
  }
}
